<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        mc:Ignorable="d" 
        x:Class="канбанчик.MainWindow"
        Title="КАНБАН ДЕМО v1.0 (WPF)" 
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        MinWidth="900" MinHeight="600"
        FontFamily="Segoe UI"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="RoundedButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1F618D"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#95A5A6"/>
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GreenButton" BasedOn="{StaticResource RoundedButton}" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#2ECC71"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#27AE60"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E8449"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RoundedTextBox" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border Background="White"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- УДАЛЯЕМ СТИЛЬ SmallTextBox - он делает шрифт слишком маленьким -->

        <DropShadowEffect x:Key="Shadow" 
                          BlurRadius="15" 
                          Opacity="0.1" 
                          Direction="270"
                          ShadowDepth="2"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель - ввод данных -->
        <Border Grid.Column="0" 
                Background="White" 
                CornerRadius="8" 
                Padding="15"
                BorderBrush="#DDD" 
                BorderThickness="1"
                Effect="{StaticResource Shadow}">

            <StackPanel>
                <TextBlock Text="КАНБАН" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="#2C3E50"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Ввод данных (ДЕМО-РЕЖИМ)" 
                           FontSize="14" 
                           FontWeight="SemiBold" 
                           Foreground="#34495E"
                           Margin="0,0,0,15"/>

                <!-- ЗНП - НОРМАЛЬНЫЙ ШРИФТ -->
                <TextBlock Text="ЗНП:" 
                           FontSize="14" 
                           Foreground="#7F8C8D"
                           Margin="0,0,0,3"/>
                <TextBox x:Name="txtJob" 
                         Style="{StaticResource RoundedTextBox}"
                         FontSize="14"
                         Height="40"
                         ToolTip="Введите номер ЗНП (например, DEMO001)"
                         TextChanged="txtJob_TextChanged"/>

                <!-- Суффикс - НОРМАЛЬНЫЙ ШРИФТ -->
                <TextBlock Text="Суффикс:" 
                           FontSize="14" 
                           Foreground="#7F8C8D"
                           Margin="0,10,0,3"/>
                <TextBox x:Name="txtSuffix" 
                         Style="{StaticResource RoundedTextBox}"
                         FontSize="14"
                         Height="40"
                         ToolTip="Введите суффикс (например, 01)"
                         TextChanged="txtSuffix_TextChanged"/>

                <!-- Количество -->
                <TextBlock Text="Количество:" 
                           FontSize="14" 
                           Foreground="#7F8C8D"
                           Margin="0,10,0,3"/>
                <TextBox x:Name="txtPages" 
                         Style="{StaticResource RoundedTextBox}"
                         FontSize="14"
                         Height="40"
                         TextChanged="txtPages_TextChanged" 
                         Text="1"/>

                <!-- Чекбокс A6 -->
                <CheckBox x:Name="chkA6" 
                          Content="Использовать формат A6" 
                          FontSize="14"
                          Foreground="#2C3E50"
                          Margin="0,15,0,10"
                          Checked="chkA6_CheckedChanged"
                          Unchecked="chkA6_CheckedChanged"/>

                <!-- Кнопка Предпросмотр -->
                <Button x:Name="btnPreview" 
                        Style="{StaticResource RoundedButton}"
                        Content="ПРЕДПРОСМОТР" 
                        Margin="0,5,0,5"
                        IsEnabled="False"
                        Click="btnPreview_Click"/>

                <!-- Кнопка Печать -->
                <Button x:Name="btnPrint" 
                        Style="{StaticResource GreenButton}"
                        Content="ПЕЧАТЬ (ДЕМО)" 
                        Margin="0,5,0,5"
                        IsEnabled="False"
                        Click="btnPrint_Click"/>

                <!-- Статусная панель -->
                <Border Background="#ECF0F1"
                        CornerRadius="4"
                        Padding="10"
                        Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock Text="ТЕКУЩЕЕ ЗАДАНИЕ" 
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#7F8C8D"
                                   Margin="0,0,0,5"/>
                        <TextBlock x:Name="lblJobInfo" 
                                   Text="Не загружено"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#2C3E50"
                                   Margin="0,0,0,3"/>
                        <TextBlock x:Name="lblPrintStatus" 
                                   Text="Статус печати: ожидание"
                                   FontSize="11"
                                   Foreground="#7F8C8D"/>
                    </StackPanel>
                </Border>

                <!-- Информация о демо-режиме -->
                <Border Background="#FFF3CD"
                        CornerRadius="4"
                        Padding="10"
                        Margin="0,10,0,0">
                    <TextBlock Text="⚠ ДЕМО-РЕЖИМ&#xA;Работает без подключения к БД&#xA;Введите любые значения"
                               FontSize="11"
                               Foreground="#856404"
                               TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Разделитель -->
        <GridSplitter Grid.Column="1"
                      HorizontalAlignment="Stretch"
                      Width="5"
                      Background="Transparent"/>

        <!-- Правая панель - предпросмотр -->
        <Border Grid.Column="2"
                Background="White"
                CornerRadius="8"
                Padding="15"
                BorderBrush="#DDD" 
                BorderThickness="1">

            <ScrollViewer VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Auto">
                <Grid>
                    <TextBlock x:Name="lblPreview" 
                               Text="ДЕМО-ВЕРСИЯ&#xA;&#xA;Введите данные и нажмите Предпросмотр"
                               FontSize="16"
                               Foreground="#BDC3C7"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               LineHeight="30"
                               Visibility="Visible"/>
                    <ContentControl x:Name="previewContent" Visibility="Collapsed"/>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>